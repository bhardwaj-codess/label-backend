<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Product Labels</title>
  <style>
   body {
     font-family: calibar, sans-serif;
     margin: 10mm;
     padding: 0;
     /* --- THIS IS THE NEW CSS FOR THE GRID LAYOUT --- */
     display: grid;
     grid-template-columns: 3.7in 3.7in; /* Creates two columns of 4 inches each */
     grid-auto-rows: 2in; /* Sets the height of each row */
     gap: 8mm; /* Spacing between labels */
   }
   .label-container {
     /* The container itself now no longer needs a fixed width/height because the grid does it */
     border: 1px solid #000;
     padding: 10px;
     box-sizing: border-box;
     display: flex;
     flex-direction: column;
   }
   .header {
     display: flex;
     flex-direction: column;
     align-items: flex-start;
     margin-bottom: 15px;
   }
   .logo {
     width: 100px;
     height: auto;
   }
   .logo-text {
     font-size: 8px;
     margin-top: 2px;
     margin-left: 7px;
   }
   .main-info {
     text-align: center;
     flex-grow: 1;
     display: flex;
     flex-direction: column;
     justify-content: center;
   }
   .main-info h3 {
     font-size: 16px;
     font-weight: bold;
     margin: 0;
     padding: 0;
   }
   .main-info p {
     font-size: 14px;
     font-weight: bold;
     margin: 5px 0 0 0;
   }

   .footer {
  display: flex;
  justify-content: space-evenly;
  align-items: flex-end;
  margin-top: auto;
}

.footer-left {
  /* Removed flex-grow to stop it from expanding */
  display: flex; 
  align-items: flex-end; 
  /* Use gap to create uniform spacing between items */
  gap: 25px; 
  font-size: 14px;
  font-weight: bold;  
}

.qr-code {
  width: 60px;
  height: auto;
}

  </style>
</head>
<body>
  <% labels.forEach(function(label) { %>
    <%- include('label_partial.ejs', { 
        product: label.product,
        quantity: label.quantity,
        date: label.date,
        logoBase64: label.logoBase64,
        qrCodeBase64: label.qrCodeBase64,
        brand: label.brand
    }); %>
  <% }); %>
</body>
</html>